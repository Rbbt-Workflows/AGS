AGS=/$PWD filter="*.rb *.rake Rakefile *.rdoc *.R *.sh *.js *.haml *.sass *.txt *.conf" {
 workflow.rb
 bin=bin filter="*"{
 }
 lib=lib {
  knowledge_base=knowledge_base{
   AGS.rb
  }
  sinatra.rb
  tasks=AGS/tasks{
   NTNU.rb
   gene_counts.rb
   gene_clusters.rb
   change_starts.rb
   gene_clusters=gene_clusters{
    rules.old.rb
    rules.rb
    rules_refactored.rb
   }
   INSPEcT.rb
   INSPEcT=INSPEcT{
    synthesis.rb
   }

   decoupler.rb

   offset.rb

   consistency.rb

   enrichment.rb

   excel.rb

   timepoint_heatmaps.rb
   downstream_targets.rb

   neko_benchmark.rb
   benchmarks.rb

   adhoc.rb
  }
 }
 test=test {
  test_helper.rb
 }
 data=data filter="*"{
  5Z_benchmark_020425.tsv
  AGS_dbTFs.list
  DNA_binding_and_some_likely_coTFs.13012025.list
  PD_benchmark_020425.tsv
  PI_benchmark_020425.tsv
  Roma.genes
  alternative_TF-sets_for_EXTRI1-2-regulomes.tsv
  cluster_groups.tsv
  coTFs.list
  consistency_tfs.10022025.list
  dbTFs_expressed_in_AGS.list
  gene_modules.tsv
  gene_tf_type.tsv
  good_tfs.list
  interesting_tfs.list
  interesting_tfs.list.old
  noisy_genes.list
  not_expressed.list
  super_cluster_names.tsv
  FC=FC{
   deseq2_log2foldchange_ashrshrink_outliersremoved_untreatedT0asreference_independentfiltering.txt
   deseq2_pvalue_fdradjusted_outliersremoved_untreatedT0asreference_independentfiltering.txt
   samples.txt
  }
 }
 www=www{
  views=views filter = "*"{
   AGS=AGS{
    decoupler=decoupler{
     job_result.haml
    }
    decoupler_pre=decoupler_pre{
     job_result.haml
    }
    timepoint_matrix=timepoint_matrix{
     job_result.haml
    }
   }
   main=main{
    heatmaps.haml
    priority_tfs.haml
    profiles.haml
    gene_sets.haml
    gene_set_excel.haml
    test.haml
   }
   entity_list=entity_list{
    Gene.haml
    Gene=Gene{
     decoupler.haml
     expression.haml
     go_bp.haml
     graph.haml
     heatmap.haml
     over_representation.haml
    }
   }
   entity=entity{
    Cluster.haml
    Gene.haml
    Gene=Gene{
     change_offsets.haml
     expression_profiles.haml
     target_gene_heatmap.haml
    }
    Treatment.haml
    Treatment=Treatment{
     heatmaps.haml
    }
   }
  }
 }
}
